<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.automotive" android:required="true" />

    <uses-permission android:name="android.car.permission.CAR_INFO" />
    <uses-permission android:name="android.car.permission.CAR_SPEED" />
    <uses-permission android:name="android.car.permission.CAR_ENERGY" />
    <uses-permission android:name="android.car.permission.CAR_ENGINE_DETAILED" />
    <uses-permission android:name="android.car.permission.CAR_STEERING" />
    <uses-permission android:name="android.car.permission.CAR_BRAKE" />
    <uses-permission android:name="android.car.permission.CAR_POWERTRAIN" />

    <permission android:name="com.smartcabin.permission.BIND_DRIVER_MONITOR" android:protectionLevel="signature" />
    <uses-permission android:name="com.smartcabin.permission.BIND_DRIVER_MONITOR" />

    <application
        android:name=".SmartDriveApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartDriveMonitor">
        <uses-library android:name="android.car" android:required="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SmartDriveMonitor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service android:name=".nativecore.DriverMonitorService" 
                 android:process=":daemon" 
                 android:permission="com.smartcabin.permission.BIND_DRIVER_MONITOR" 
                 android:exported="true" />
    </application>

</manifest>